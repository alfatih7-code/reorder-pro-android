<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/header_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardBackgroundColor="#1E293B"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="15dp">

            <ImageButton
                android:id="@+id/btn_sort_order"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_sort_by_size"
                app:tint="#38BDF8"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <ImageView
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:src="@android:drawable/ic_menu_save"
                    app:tint="#38BDF8" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ReOrder Pro"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chronological Management"
                    android:textColor="#38BDF8"
                    android:textSize="10sp"
                    android:alpha="0.7" />
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/options_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        android:visibility="gone"
        app:cardBackgroundColor="#1E293B"
        app:cardCornerRadius="20dp"
        app:layout_constraintTop_toBottomOf="@id/header_card"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="REORDERING STYLE"
                android:textColor="#38BDF8"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <RadioGroup
                android:id="@+id/namingOptionsGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="4">
                <RadioButton android:id="@+id/radio_smart" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Smart" android:textColor="#FFFFFF" android:buttonTint="#38BDF8" android:textSize="10sp" android:checked="true"/>
                <RadioButton android:id="@+id/radio_original" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Origin" android:textColor="#FFFFFF" android:buttonTint="#38BDF8" android:textSize="10sp"/>
                <RadioButton android:id="@+id/radio_numbers" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Num" android:textColor="#FFFFFF" android:buttonTint="#38BDF8" android:textSize="10sp"/>
                <RadioButton android:id="@+id/radio_custom" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Custom" android:textColor="#FFFFFF" android:buttonTint="#38BDF8" android:textSize="10sp"/>
            </RadioGroup>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/custom_name_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                android:hint="Prefix (e.g. Lecture)"
                app:hintTextColor="#38BDF8"
                app:boxStrokeColor="#38BDF8"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_custom_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:inputType="text"/>
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_files"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:clipToPadding="false"
        android:paddingBottom="140dp"
        app:layout_constraintTop_toBottomOf="@id/options_card"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <LinearLayout
        android:id="@+id/bottom_controller"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@drawable/bottom_gradient_shade"
        app:layout_constraintBottom_toBottomOf="parent">

        <ProgressBar
            android:id="@+id/main_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:indeterminate="true"
            android:indeterminateTint="#38BDF8"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/status_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select a folder to begin"
            android:textColor="#94A3B8"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginBottom="16dp"
            android:textStyle="italic"
            android:alpha="0.8"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_undo"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="0dp"
                android:layout_weight="1.2"
                android:layout_height="match_parent"
                android:layout_marginEnd="10dp"
                android:visibility="gone"
                app:cornerRadius="18dp"
                app:icon="@android:drawable/ic_menu_revert"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:backgroundTint="#F43F5E"
                tools:visibility="gone"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_new_folder"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="0dp"
                android:layout_weight="2.5"
                android:layout_height="match_parent"
                android:text="NEW"
                android:textColor="#FFFFFF"
                android:visibility="gone"
                app:cornerRadius="18dp"
                app:icon="@android:drawable/ic_input_add"
                app:backgroundTint="#334155"
                tools:visibility="gone"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pick"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="0dp"
                android:layout_weight="3"
                android:layout_height="match_parent"
                android:text="CHANGE"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                app:cornerRadius="18dp"
                app:icon="@android:drawable/ic_menu_search"
                app:backgroundTint="#38BDF8"
                tools:layout_width="0dp"
                tools:layout_weight="1.5" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_apply"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="0dp"
                android:layout_weight="4"
                android:layout_height="match_parent"
                android:layout_marginStart="10dp"
                android:text="APPLY"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:cornerRadius="18dp"
                app:icon="@android:drawable/ic_menu_send"
                app:backgroundTint="#10B981"
                tools:visibility="visible"/>

        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>