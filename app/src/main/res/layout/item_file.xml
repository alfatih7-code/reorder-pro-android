<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/glass_white"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeColor="#334155"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/img_file_type"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:src="@android:drawable/ic_menu_agenda"
            app:tint="@color/neon_blue"
            android:padding="6dp"
            android:background="@drawable/icon_bg_circle" /> <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="14dp">

        <TextView
            android:id="@+id/file_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="File_Name_01.mp4"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:ellipsize="middle"
            android:maxLines="1"/>

        <TextView
            android:id="@+id/file_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VIDEO"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:letterSpacing="0.1"
            android:layout_marginTop="2dp"
            android:textStyle="bold"/>
    </LinearLayout>

        <ImageView
            android:id="@+id/status_indicator"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:src="@android:drawable/button_onoff_indicator_on"
            android:visibility="gone"
            app:tint="@color/neon_blue"
            android:layout_marginStart="8dp"
            tools:visibility="visible"/>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>