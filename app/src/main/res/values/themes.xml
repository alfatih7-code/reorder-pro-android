<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.ReOrderPro" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/neon_blue</item>
        <item name="colorOnPrimary">@color/primary_dark</item>
        <item name="android:statusBarColor">@color/bg_gradient_start</item>
        <item name="android:windowBackground">@color/bg_gradient_start</item>

        <item name="materialButtonStyle">@style/Widget.Material3.Button.UnelevatedButton</item>

        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/bg_gradient_start</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.ReOrderPro</item>
        <item name="windowSplashScreenAnimationDuration">800</item>
    </style>

    <style name="TextStyle">
        <item name="android:textColor">@color/white</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextStyle.NeonHeader">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

</resources>